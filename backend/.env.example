PORT=3000
APP_URL=http://localhost:3000

# API URL for frontend → set in frontend/.env (not here)
# See frontend/.env.example

# CORS — only needed when frontend and backend are on different domains
# FRONTEND_URL=https://your-frontend.vercel.app

MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/herstyle?retryWrites=true&w=majority
JWT_SECRET=your-long-random-secret-min-32-chars
GROQ_API_KEY=gsk_...

# Email — Brevo (recommended)
# Dashboard: https://app.brevo.com → Senders (verify email) → SMTP & API → Create API key
BREVO_API_KEY=xkeysib-...
EMAIL_FROM=HERSTYLE <your-verified-email@gmail.com>

# Optional SMTP fallback (Brevo → SMTP & API → SMTP key)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email@gmail.com
# SMTP_PASS=xsmtpsib-...

EMAIL_FROM=HERSTYLE <your-verified-email@gmail.com>

# Admin — comma-separated; auto-promoted on server start (register first, then restart)
ADMIN_EMAILS=subhu1704@gmail.com,sharma151104@gmail.com

# Google OAuth — Client ID → frontend/.env | Secret → backend/.env (never frontend!)
# Redirect URI: {API_URL or APP_URL}/auth/google/callback
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: fixed INR→USD rate (1 INR in USD). Leave empty for live rate.
# INR_USD_RATE=0.012
