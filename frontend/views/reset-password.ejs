<%- include('partials/head', { pageTitle: 'Reset Password | HERSTYLE', bodyClass: 'auth-page' }) %>

<nav class="fixed top-0 left-0 right-0 z-50 flex h-16 items-center justify-between border-b border-gray-100 bg-white/95 px-6 backdrop-blur-md md:px-10">
  <a href="/" class="logo flex items-center gap-2.5 font-serif text-lg font-semibold tracking-[0.15em] text-brand-dark">
    <%- include('partials/logo-icon') %>
    <span>HERSTYLE</span>
  </a>
  <a href="/login" class="text-sm font-medium text-gray-600 transition hover:text-brand-gold">Login</a>
</nav>

<div class="auth-wrapper">
  <div class="auth-card">
    <h1>Set New Password</h1>
    <p class="auth-subtitle">Choose a strong password (min 6 characters)</p>
    <form id="resetForm">
      <input type="password" name="password" placeholder="New password" required minlength="6">
      <input type="password" name="confirm" placeholder="Confirm password" required minlength="6">
      <button type="submit">Reset Password</button>
    </form>
    <p class="auth-link"><a href="/login">← Back to login</a></p>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const params = new URLSearchParams(window.location.search);
const token = params.get('token');
if (!token) showToast('Invalid reset link', 'error');

document.getElementById('resetForm').onsubmit = async (e) => {
  e.preventDefault();
  const f = e.target;
  if (f.password.value !== f.confirm.value) { showToast('Passwords do not match', 'error'); return; }
  const res = await fetch(apiUrl('/api/auth/reset-password'), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ token, newPassword: f.password.value }),
  });
  const data = await res.json();
  if (!res.ok) { showToast(data.error, 'error'); return; }
  showToast(data.message, 'success');
  setTimeout(() => { window.location.href = '/login'; }, 1500);
};
</script>
<%- include('partials/end') %>
