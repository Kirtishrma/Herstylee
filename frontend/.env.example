# ─── Render / backend URL (API + Google OAuth redirect) ───
# Local monolith: leave empty (same server on :3000)
# Production: paste your Render service URL
# API_URL=https://herstyle-api.onrender.com
API_URL=

# ─── Google OAuth (Client ID only — public, safe here) ───
# Google Cloud Console → APIs & Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {API_URL}/auth/google/callback
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
