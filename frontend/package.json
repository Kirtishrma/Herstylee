{
  "name": "herstyle-frontend",
  "version": "2.0.0",
  "private": true,
  "description": "HERSTYLE frontend — Tailwind CSS + ES modules",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/app.css --minify",
    "build:js": "esbuild src/js/main.js --bundle --outfile=public/js/app.js --format=iife --global-name=Herstyle",
    "build": "npm run build:css && npm run build:js",
    "dev:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/app.css --watch",
    "dev:js": "esbuild src/js/main.js --bundle --outfile=public/js/app.js --format=iife --global-name=Herstyle --watch",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.5",
    "postcss": "^8.5.4",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.17"
  }
}
