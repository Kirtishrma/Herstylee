<%- include('partials/head', { pageTitle: 'Wishlist | HERSTYLE' }) %>
<%- include('partials/header') %>
<main class="page-shell">
  <nav class="page-breadcrumb">
    <a href="/">Home</a><span>/</span><span>Wishlist</span>
  </nav>
  <header class="page-head">
    <span class="page-tag">Saved</span>
    <h1>Your Wishlist</h1>
    <p class="page-sub">Outfits you've saved for later.</p>
  </header>
  <div id="wishContent"></div>
</main>
<%- include('partials/footer') %>
<script src="/js/app.js"></script>
<script>
async function loadWishlist() {
  const el = document.getElementById('wishContent');
  if (!getToken()) {
    el.innerHTML = '<div class="empty-state"><p>Please <a href="/login">login</a> to view your wishlist.</p></div>';
    return;
  }

  el.innerHTML = `<div class="catalog-grid">${skeletonGridHtml(4)}</div>`;

  try {
    const res = await authFetch('/api/wishlist');
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Could not load wishlist');

    const products = data.products || [];
    if (!products.length) {
      el.innerHTML = '<div class="empty-state"><p>Your wishlist is empty.</p><a href="/search">Discover dresses →</a></div>';
      return;
    }

    el.innerHTML = `<div class="catalog-grid">${products.map(p => `
      <div class="catalog-card">
        <a href="/product/${p.slug}" class="catalog-img-wrap"><img src="${p.image}" alt="${p.name}"></a>
        <div class="catalog-info">
          <span class="catalog-cat">${p.category}</span>
          <h3>${p.name}</h3>
          <p class="catalog-price">₹${p.price.toLocaleString('en-IN')}</p>
        </div>
        <div class="catalog-card-actions">
          <button class="btn-sm btn-dark" onclick="addToCart('${p.id}')">Add to Cart</button>
          <button class="btn-sm btn-outline" onclick="removeWish('${p.id}')">Remove</button>
        </div>
      </div>`).join('')}</div>`;
  } catch (err) {
    el.innerHTML = `<div class="empty-state"><p>${err.message || 'Could not load wishlist.'}</p><button type="button" class="btn-sm btn-dark" onclick="loadWishlist()">Try again</button></div>`;
  }
}
async function removeWish(id) {
  await toggleWishlist(id);
  loadWishlist();
  updateNavBadges();
}
loadWishlist();
</script>
<%- include('partials/end') %>
