<%- include('partials/head', { pageTitle: title + ' | HERSTYLE' }) %>
<%- include('partials/header') %>

<main class="page-shell product-page">
  <nav class="page-breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/<%= collectionPath %>"><%= categoryLabel %></a>
    <span>/</span>
    <span><%= title %></span>
  </nav>

  <section class="product-hero">
    <div class="product-image-wrap">
      <img src="<%= image %>" alt="<%= title %>" class="product-main-image">
    </div>

    <div class="product-info-panel">
      <p class="product-category"><%= categoryLabel %></p>
      <h1><%= title %></h1>
      <div class="product-rating-live" id="productRatingLive">
        <span class="stars">★★★★★</span>
        <span id="ratingText">Loading reviews...</span>
      </div>
      <p class="product-price"><%= priceFormatted %></p>
      <p class="product-desc"><%= description %></p>

      <div class="product-sizes">
        <h3>Select Size</h3>
        <div class="size-options">
          <button type="button" class="size-btn">XS</button>
          <button type="button" class="size-btn">S</button>
          <button type="button" class="size-btn active">M</button>
          <button type="button" class="size-btn">L</button>
          <button type="button" class="size-btn">XL</button>
        </div>
      </div>

      <div class="product-actions">
        <button type="button" class="btn-cart" id="addCartBtn">Add to Cart</button>
        <button type="button" class="btn-wish" id="wishBtn">♥ Wishlist</button>
      </div>
      <p id="productMsg" class="product-msg"></p>

      <ul class="product-trust">
        <li>✓ Free shipping on orders above ₹2,999</li>
        <li>✓ Easy 7-day returns</li>
        <li>✓ Secure checkout</li>
      </ul>
    </div>
  </section>

  <section class="product-details-grid">
    <div class="detail-card">
      <h2>Product Details</h2>
      <ul>
        <li><strong>Collection:</strong> <%= categoryLabel %></li>
        <li><strong>Fit:</strong> Regular fit, true to size</li>
        <li><strong>Fabric:</strong> Premium blend — breathable & comfortable</li>
        <li><strong>Care:</strong> Dry clean recommended</li>
        <li><strong>Style:</strong> Designed for modern women</li>
      </ul>
    </div>
    <div class="detail-card">
      <h2>Size Guide</h2>
      <table class="size-table">
        <thead>
          <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hip</th></tr>
        </thead>
        <tbody>
          <tr><td>XS</td><td>32"</td><td>24"</td><td>34"</td></tr>
          <tr><td>S</td><td>34"</td><td>26"</td><td>36"</td></tr>
          <tr><td>M</td><td>36"</td><td>28"</td><td>38"</td></tr>
          <tr><td>L</td><td>38"</td><td>30"</td><td>40"</td></tr>
          <tr><td>XL</td><td>40"</td><td>32"</td><td>42"</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="product-reviews panel" id="reviewsSection">
    <div class="reviews-header">
      <h2>Customer Reviews</h2>
      <p id="reviewsSummary">Loading...</p>
    </div>
    <div id="reviewFormWrap" class="review-form-wrap" hidden>
      <h3>Write a Review</h3>
      <form id="reviewForm">
        <label>Rating</label>
        <div class="star-picker" id="starPicker">
          <button type="button" data-star="1">★</button>
          <button type="button" data-star="2">★</button>
          <button type="button" data-star="3">★</button>
          <button type="button" data-star="4">★</button>
          <button type="button" data-star="5">★</button>
        </div>
        <input type="hidden" name="rating" id="reviewRating" value="5">
        <label>Your review</label>
        <textarea name="comment" rows="3" placeholder="Share your experience..." required minlength="5"></textarea>
        <button type="submit" class="btn-primary">Submit Review</button>
      </form>
    </div>
    <p id="reviewLoginHint" class="review-login-hint"><a href="/login">Login</a> to write a review</p>
    <div id="reviewsList" class="reviews-list"></div>
  </section>

  <% if (related && related.length) { %>
  <section class="product-related">
    <h2>You May Also Like</h2>
  <div class="related-grid catalog-grid">
      <% related.forEach(function(p) { %>
      <a href="/product/<%= p.slug %>" class="related-item catalog-card">
        <div class="catalog-img-wrap"><img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy"></div>
        <div class="catalog-info">
          <span class="catalog-cat"><%= p.category %></span>
          <h3><%= p.name %></h3>
          <p class="catalog-price">₹<%= p.price.toLocaleString('en-IN') %></p>
        </div>
      </a>
      <% }); %>
    </div>
  </section>
  <% } %>
</main>
<%- include('partials/footer') %>
<script src="/js/app.js"></script>
<script>
const productId = '<%= productId %>';

trackRecentlyViewed(<%- JSON.stringify({ slug: slug, name: title, image: image, price: price, category: categoryLabel }) %>);

let selectedRating = 5;
document.querySelectorAll('#starPicker button').forEach(btn => {
  btn.onclick = () => {
    selectedRating = Number(btn.dataset.star);
    document.getElementById('reviewRating').value = selectedRating;
    document.querySelectorAll('#starPicker button').forEach(b => {
      b.classList.toggle('active', Number(b.dataset.star) <= selectedRating);
    });
  };
});
document.querySelectorAll('#starPicker button').forEach(b => b.classList.add('active'));

async function loadReviews() {
  const res = await fetch(apiUrl(`/api/products/${productId}/reviews`));
  const data = await res.json();
  const avg = data.average || 0;
  const count = data.count || 0;

  document.getElementById('ratingText').textContent = count
    ? `${avg} · ${count} review${count > 1 ? 's' : ''}`
    : 'No reviews yet';
  document.getElementById('reviewsSummary').textContent = count
    ? `${avg} out of 5 · ${count} customer review${count > 1 ? 's' : ''}`
    : 'Be the first to review this product';

  const list = document.getElementById('reviewsList');
  if (!data.reviews.length) {
    list.innerHTML = '<p class="review-empty">No reviews yet. Be the first!</p>';
  } else {
    list.innerHTML = data.reviews.map(r => `
      <div class="review-card">
        <div class="review-card-head">
          <strong>${escapeHtml(r.userName)}</strong>
          <span class="review-stars">${'★'.repeat(r.rating)}${'☆'.repeat(5 - r.rating)}</span>
        </div>
        <p>${escapeHtml(r.comment)}</p>
        <span class="review-date">${new Date(r.createdAt).toLocaleDateString('en-IN')}</span>
      </div>`).join('');
  }
}

function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

if (getToken()) {
  document.getElementById('reviewFormWrap').hidden = false;
  document.getElementById('reviewLoginHint').hidden = true;
  authFetch(`/api/wishlist/check/${productId}`).then(r => r.json()).then(d => {
    if (d.saved) document.getElementById('wishBtn').textContent = '♥ Saved';
  }).catch(() => {});
}

document.getElementById('reviewForm').onsubmit = async (e) => {
  e.preventDefault();
  const comment = e.target.comment.value.trim();
  const res = await authFetch(`/api/products/${productId}/reviews`, {
    method: 'POST',
    body: JSON.stringify({ rating: selectedRating, comment }),
  });
  const data = await res.json();
  if (!res.ok) {
    showToast(data.error, 'error');
    return;
  }
  showToast(data.message, 'success');
  e.target.reset();
  selectedRating = 5;
  document.querySelectorAll('#starPicker button').forEach(b => b.classList.add('active'));
  loadReviews();
};

loadReviews();

let selectedSize = 'M';
document.querySelectorAll('.size-btn').forEach(btn => {
  btn.onclick = () => {
    document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedSize = btn.textContent.trim();
  };
});

document.getElementById('addCartBtn').onclick = async () => {
  try {
    await addToCart(productId, 1, { silent: true, size: selectedSize });
    showToast(`Added size ${selectedSize} to cart!`, 'success');
  } catch (e) {
    showToast(e.message, 'error');
  }
};

document.getElementById('wishBtn').onclick = async () => {
  try {
    const r = await toggleWishlist(productId, { silent: true });
    showToast(r.added ? 'Saved to wishlist!' : 'Removed from wishlist', 'success');
    document.getElementById('wishBtn').textContent = r.added ? '♥ Saved' : '♥ Wishlist';
  } catch (e) {
    showToast(e.message, 'error');
  }
};

if (getToken()) {
  authFetch(`/api/wishlist/check/${productId}`).then(r => r.json()).then(d => {
    if (d.saved) document.getElementById('wishBtn').textContent = '♥ Saved';
  }).catch(() => {});
}
</script>
<%- include('partials/end') %>
