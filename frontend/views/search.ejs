<%- include('partials/head', { pageTitle: 'Shop | HERSTYLE' }) %>
<%- include('partials/header') %>
<main class="page-shell">
  <nav class="page-breadcrumb">
    <a href="/">Home</a><span>/</span><span>Shop</span>
  </nav>
  <header class="page-head">
    <span class="page-tag">Browse</span>
    <h1>Shop All Dresses</h1>
    <p class="page-sub">Search by name, filter by category and price — find your perfect outfit.</p>
  </header>

  <form class="search-bar" method="GET" action="/search">
    <input type="hidden" name="page" value="1">
    <input type="text" name="q" value="<%= q %>" placeholder="Search dresses, lehenga, formal...">
    <select name="category">
      <option value="">All Categories</option>
      <% categories.forEach(cat => { %>
      <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
      <% }) %>
    </select>
    <select name="sort">
      <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
      <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
      <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>Name: A–Z</option>
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest First</option>
    </select>
    <input type="number" name="minPrice" value="<%= minPrice %>" placeholder="Min ₹" min="0">
    <input type="number" name="maxPrice" value="<%= maxPrice %>" placeholder="Max ₹" min="0">
    <button type="submit">Search</button>
  </form>

  <div class="search-results-meta">
    <p class="page-count"><%= count %> product(s) found</p>
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <p class="page-count-sub">Page <%= page %> of <%= totalPages %></p>
    <% } %>
  </div>

  <% if (products.length === 0) { %>
  <div class="empty-state"><p>No products match your search.</p><a href="/search">Clear filters</a></div>
  <% } else { %>
  <div class="catalog-grid">
    <% products.forEach(p => { %>
    <div class="catalog-card">
      <a href="/product/<%= p.slug %>" class="catalog-img-wrap"><img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy"></a>
      <div class="catalog-info">
        <span class="catalog-cat"><%= p.category %></span>
        <h3><%= p.name %></h3>
        <p class="catalog-price">₹<%= p.price.toLocaleString('en-IN') %></p>
      </div>
      <div class="catalog-card-actions">
        <button class="btn-sm btn-dark" onclick="addToCart('<%= p._id %>')">Add to Cart</button>
        <button type="button" class="btn-sm btn-outline" onclick="searchToggleWish('<%= p._id %>')">♥</button>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
  <nav class="pagination" aria-label="Search results pages">
    <% const queryBase = `q=${encodeURIComponent(q || '')}&category=${encodeURIComponent(category || '')}&minPrice=${minPrice || ''}&maxPrice=${maxPrice || ''}&sort=${sort || 'price_asc'}`; %>
    <% if (page > 1) { %>
    <a href="/search?<%= queryBase %>&page=<%= page - 1 %>" class="page-btn">← Prev</a>
    <% } %>
    <% for (let p = 1; p <= totalPages; p++) { %>
      <% if (p === 1 || p === totalPages || (p >= page - 2 && p <= page + 2)) { %>
    <a href="/search?<%= queryBase %>&page=<%= p %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
      <% } else if (p === page - 3 || p === page + 3) { %>
    <span class="page-ellipsis">…</span>
      <% } %>
    <% } %>
    <% if (page < totalPages) { %>
    <a href="/search?<%= queryBase %>&page=<%= page + 1 %>" class="page-btn">Next →</a>
    <% } %>
  </nav>
  <% } %>
  <% } %>
</main>
<%- include('partials/footer') %>
<script src="/js/app.js"></script>
<script>
async function searchToggleWish(id) {
  if (!getToken()) {
    window.location.href = '/login';
    return;
  }
  try {
    await toggleWishlist(id);
  } catch (e) {
    showToast(e.message, 'error');
  }
}
</script>
<%- include('partials/end') %>
