<%- include('partials/head', { pageTitle: 'Login | HERSTYLE', bodyClass: 'auth-page' }) %>

<nav class="fixed top-0 left-0 right-0 z-50 flex h-16 items-center justify-between border-b border-gray-100 bg-white/95 px-6 backdrop-blur-md md:px-10">
  <a href="/" class="logo flex items-center gap-2.5 font-serif text-lg font-semibold tracking-[0.15em] text-brand-dark">
    <%- include('partials/logo-icon') %>
    <span>HERSTYLE</span>
  </a>
  <a href="/signin" class="text-sm font-medium text-gray-600 transition hover:text-brand-gold">Sign Up</a>
</nav>

<div class="auth-wrapper">
  <div class="auth-card">
    <h1>Welcome Back</h1>
    <p class="auth-subtitle">Login to chat with Style Muse</p>
    <p class="auth-error" id="errorMsg"></p>

    <a href="#" class="btn-google" id="googleBtn" hidden>
      <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303C33.654 32.657 29.083 36 24 36c-5.522 0-10-4.478-10-10s4.478-10 10-10c2.837 0 5.352 1.178 7.188 3.071l5.657-5.657C33.64 6.053 29.082 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.651-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c2.837 0 5.352 1.178 7.188 3.071l5.657-5.657C33.64 6.053 29.082 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.006-.005 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.651-.389-3.917z"/></svg>
      Continue with Google
    </a>

    <div class="auth-divider" id="authDivider" hidden><span>or</span></div>

    <form id="loginForm">
      <input type="email" name="email" placeholder="Email" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>
    <p class="auth-link"><a href="/forgot-password">Forgot password?</a></p>
    <p class="auth-link">New here? <a href="/signin">Create account</a></p>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const errorEl = document.getElementById('errorMsg');
const urlErrors = {
  google_denied: 'Google sign-in was cancelled.',
  google_failed: 'Google sign-in failed. Try again.',
  google_not_configured: 'Google sign-in is not configured yet.',
};
const q = new URLSearchParams(location.search).get('error');
if (q && urlErrors[q]) errorEl.textContent = urlErrors[q];

if (window.__GOOGLE_ENABLED__ === 'true' || window.__GOOGLE_CLIENT_ID__) setupGoogleAuth();

fetch(apiUrl('/api/auth/config')).then(r => r.json()).then(cfg => {
  if (cfg.googleEnabled || cfg.googleClientId) setupGoogleAuth();
}).catch(function() { setupGoogleAuth(); });

document.getElementById('loginForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  errorEl.textContent = '';
  const res = await fetch(apiUrl('/api/auth/login'), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify({ email: form.email.value, password: form.password.value }),
  });
  const data = await res.json();
  if (!res.ok) { errorEl.textContent = data.error; return; }
  localStorage.setItem(TOKEN_KEY, data.token);
  window.location.href = data.redirect || (data.user?.isAdmin ? '/admin' : '/profile');
});
</script>
<%- include('partials/end') %>
